# Frontend URL (used in verification emails, password reset links)
FRONTEND_URL=http://localhost:5173
COOKIE_DOMAIN=
COOKIE_SECURE=false

# Security
SECRET_KEY=your-secret-key-here-change-in-production
ENCRYPTION_KEY=your-encryption-key-here-change-in-production
GOOGLE_CLIENT_ID=

# Database
POSTGRES_SERVER=localhost
POSTGRES_USER=taxja
POSTGRES_PASSWORD=taxja_password
POSTGRES_DB=taxja
POSTGRES_PORT=5432

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# MinIO/S3
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=taxja-documents
MINIO_SECURE=false

# LLM Configuration
# Priority: Groq > OpenAI > GPT-OSS > Ollama

# Option 0: Self-hosted vLLM on GPU server (optional)
# 测试阶段: RunPod 按小时付费 → deploy/runpod/README.md
# 生产环境: Hetzner GEX44 按月付费 → deploy/gpu-server/README.md
# 验证连接: python deploy/check_llm_server.py
GPT_OSS_ENABLED=false
GPT_OSS_BASE_URL=http://your-gpu-server:8080/v1
GPT_OSS_MODEL=Qwen/Qwen2.5-32B-Instruct-AWQ
GPT_OSS_API_KEY=your-vllm-api-key

# Option 1: Groq API (Fast & Free)
# Get free API key from: https://console.groq.com/keys
GROQ_ENABLED=false
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Option 2: OpenAI API
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
CONTRACT_ROLE_MODE=legacy

# Option 3: Ollama (Local LLM - CPU only, slow)
OLLAMA_ENABLED=false
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b

# CORS
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Historical Data Import
# Maximum file size for historical document uploads (in MB)
HISTORICAL_IMPORT_MAX_FILE_SIZE_MB=50

# Retention period for historical import data (in days)
# After this period, import sessions and extracted data may be archived
HISTORICAL_IMPORT_RETENTION_DAYS=90

# Minimum confidence threshold for auto-approval (0.0-1.0)
# Imports below this threshold will require manual review
HISTORICAL_IMPORT_MIN_CONFIDENCE=0.7

# Enable automatic property linking based on address matching
# When true, properties will be auto-linked if confidence > 0.9
# When false, all property links require manual approval
HISTORICAL_IMPORT_ENABLE_AUTO_LINK=true

# Stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PLUS_MONTHLY_PRICE_ID=
STRIPE_PLUS_YEARLY_PRICE_ID=
STRIPE_PRO_MONTHLY_PRICE_ID=
STRIPE_PRO_YEARLY_PRICE_ID=
STRIPE_OVERAGE_PRODUCT_ID=

# Email / SMTP Notifications
ENABLE_EMAIL_NOTIFICATIONS=false
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@taxja.at
SMTP_FROM_NAME=Taxja
SMTP_USE_TLS=true
