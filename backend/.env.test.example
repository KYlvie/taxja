# Test Environment Configuration
# Copy this file to .env for running tests

# Security
SECRET_KEY=test_secret_key_minimum_32_characters_long_for_jwt_signing
ENCRYPTION_KEY=test_encryption_key_32_chars_12
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Database (PostgreSQL)
POSTGRES_SERVER=localhost
POSTGRES_USER=taxja
POSTGRES_PASSWORD=taxja_password
POSTGRES_DB=taxja_test
POSTGRES_PORT=5432

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# MinIO/S3 Storage
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=taxja-documents-test
MINIO_SECURE=false

# CORS
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# LLM / OpenAI (optional for tests)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Celery (optional for tests)
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

# Historical Data Import
HISTORICAL_IMPORT_MAX_FILE_SIZE_MB=50
HISTORICAL_IMPORT_RETENTION_DAYS=90
HISTORICAL_IMPORT_MIN_CONFIDENCE=0.7
HISTORICAL_IMPORT_ENABLE_AUTO_LINK=true
